{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information for a registered user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "minecraftUsername": {
          "type": "string",
          "description": "User's in-game Minecraft username"
        },
        "rank": {
          "type": "string",
          "description": "Current highest rank: Novice, Warrior, Knight, Elite, Legend, Mythic"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Store Order",
      "description": "A purchase record for ranks or crates.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "productType": {
          "type": "string",
          "description": "rank or crate"
        },
        "productId": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "description": "pending, completed, failed"
        },
        "provider": {
          "type": "string",
          "description": "bkash, nagad"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "productType", "productId", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores purchase records. Writeable only via internal systems or validated checkouts."
    }
  }
}
